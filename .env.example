# ─────────────────────────────────────────────────────────
# BIBLIOTHÈQUE NUMÉRIQUE DIT — Template des variables d'env
# ─────────────────────────────────────────────────────────
# Copiez ce fichier en .env et remplissez les valeurs :
#   cp .env.example .env
# ─────────────────────────────────────────────────────────

# ── PostgreSQL — Base commune (Docker) ───────────────────
POSTGRES_USER=library_user
POSTGRES_PASSWORD=library_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# ── Service Livres (Port 8001) ───────────────────────────
DATABASE_URL_LIVRES=postgresql+psycopg://<USER>:<PASS>@<HOST>:<PORT>/livres_db

# ── Service Utilisateurs (Port 8002) ─────────────────────
DATABASE_URL_UTILISATEURS=postgresql+psycopg://<USER>:<PASS>@<HOST>:<PORT>/utilisateurs_db

# ── Service Emprunts (Port 8003) ─────────────────────────
DATABASE_URL_EMPRUNTS=postgresql+psycopg://<USER>:<PASS>@<HOST>:<PORT>/emprunts_db
LIVRES_SERVICE_URL=http://localhost:8001
UTILISATEURS_SERVICE_URL=http://localhost:8002

# ── Service Recommandation (Port 8004) ───────────────────
DATABASE_URL_RECOMMANDATION=postgresql+psycopg://<USER>:<PASS>@<HOST>:<PORT>/recommandation_db
MODEL_PATH=./models/model.pkl

# ── Jenkins (profil Docker Compose « ci ») ───────────────
JENKINS_HTTP_PORT=8080
JENKINS_AGENT_PORT=50000

# ── DVC Remote (Google Drive) ────────────────────────────
# GDRIVE_FOLDER_ID=<votre_id_de_dossier_google_drive>
